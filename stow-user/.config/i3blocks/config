# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks

# Global properties
separator=true
separator_block_width=15

# ---
[wifi]
#command=iwctl station wlan0 show | grep "Connected network" | sed 's/^[ \t]*//' | awk '{print " " $3}'
#command=iwctl station wlan0 show | grep "Connected network" | sed 's/^[ \t]*//' | awk '{print " "}'

#有感通知： 斷線時會明確顯示  Offline。
#顏色切換： 你甚至可以進一步判斷，若斷線則將顏色輸出為紅色（i3blocks 支援透過指令輸出第三行來動態改變顏色）。
command=SSID=$(iwctl station wlan0 show | grep "Connected network" | awk '{print $3}'); if [ -z "$SSID" ]; then echo " Offline"; else echo " $SSID"; fi

interval=5
color=#50fa7b
# ---

[bandwidth]
command=~/.config/i3blocks/scripts/bandwidth
interval=5

#[documentation]
#full_text=Documentation
#website=https://vivien.github.io/i3blocks
#command=xdg-open "$website"
#color=#f12711

#[greetings]
#color=#f5af19
#command=echo "Hello, $USER!"
